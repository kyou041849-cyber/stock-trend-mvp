# Server-side only. Do not expose these values in client code, localStorage, logs, or screenshots.
# Copy this file to .env.local when you want to test the real LLM route locally.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
LLM_API_BASE_URL=
LLM_API_FORMAT=

# Defaults:
# - LLM_API_BASE_URL empty => https://api.openai.com
# - LLM_API_FORMAT empty => responses
#
# DeepSeek / OpenAI-compatible Chat Completions:
# - LLM_API_BASE_URL=https://api.deepseek.com
# - LLM_API_FORMAT=chat-completions
# - OPENAI_MODEL=deepseek-v4-flash or deepseek-chat
# - API key is read from the server process system environment variable DEEPSEEK_API_KEY.
#   Do not commit real keys. Do not expose keys in browser UI, localStorage, logs, or screenshots.

# Server-side only. Stock price API requests go through Next.js Route Handlers.
# Do not paste these values into the browser UI or localStorage.
# STOCK_PRICE_API_BASE_URL should not include the API key in the query string.
# The server sends STOCK_PRICE_API_KEY via Authorization and X-API-Key headers.
STOCK_PRICE_API_KEY=
STOCK_PRICE_API_BASE_URL=

# Server-side only. Fundamental / financial API requests go through Next.js Route Handlers.
# Do not paste these values into the browser UI or localStorage.
FUNDAMENTAL_API_KEY=
FUNDAMENTAL_API_BASE_URL=
